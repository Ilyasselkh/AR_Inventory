<record id="view_araymond_inventory_parametres_main_form" model="ir.ui.view">
    <field name="name">araymond.maininvsession.form</field>
    <field name="model">araymond.maininvsession</field>
    <field name="arch" type="xml">
        <form create="false" delete="false">
            <header>
                <field name="state" widget="statusbar" readonly="1"/>
            </header>
            <sheet>
                <group invisible="state != 'CreationMain'">
                    <group>
                        <field name="typesession"/>
                    </group>
                    <group>
                        <field name="desc"/>
                    </group>
                    <group>
                        <field name="datesession"/>
                    </group>
                    <group>
                        <field name="lx03_file" filename="lx03_filename" widget="binary"/>
                        <field name="lx03_filename" invisible="1"/>
                        <field name="file_loaded" invisible="1"/>
                    </group>
                    <group>
                        <button string="Charger le fichier" name="action_load_file" type="object" class="btn-primary"/>
                        <button string="Suivant" name="action_creation" type="object" class="btn-success" invisible="file_loaded == False"/>
                        <field name="lxo3_records" colspan="3">
                            <list editable="bottom">
                                <field name="type_magasin"/>
                                <field name="emplacement"/>
                                <field name="article"/>
                                <field name="lot"/>
                                <field name="stock_total"/>
                                <field name="unite_qty_base"/>
                                <field name="type_unite_stock"/>
                                <field name="magasin"/>
                                <field name="su"/>
                            </list>
                        </field>
                    </group>
                </group>

                <group invisible="state != 'Creation'">
                    <group><field name="resume" readonly="1" force_save="1"/></group>
                    <group>
                        <button string="modifier" name="action_mod_empl" groups="base.group_system" type="object" class="btn-danger"/>
                        <button string="Suivant" name="action_scan_ok" type="object" class="btn-success"/>
                    </group>
                    <group>
                        <field name="sess_records" colspan="3">
                            <list editable="bottom">
                                <field name="rack"/>
                                <field name="magasinSAP"/>
                                <field name="magasinPhysique"/>
                                <field name="nbrEmp" colspan="3"/>
                                <field name="ummondatory"/>
                                <field name="dummondatory"/>
                                <field name="statusSession"/>
                            </list>
                        </field>
                    </group>
                </group>

                <group invisible="state != 'Scan'">
                    <group><field name="resume" readonly="1" force_save="1"/></group>
                    <group>
                        <button colspan="3" string="modifier" name="action_mod_empl" groups="base.group_system" type="object" class="btn-danger"/>
                    </group>
                    <group>
                        <h1 style="color: green;" colspan="3">Scan en cours</h1>
                    </group>
                </group>
            </sheet>
        </form>
    </field>
</record>

<record id="AR_Inventory.view_araymond_inventory_session_form" model="ir.ui.view">
        <field name="name">araymond.invsession.form</field>
        <field name="model">araymond.invsession</field>
        <field name="arch" type="xml">
            <form create="false" delete="false">
                <header>
                    <button colspan="3" string="modifier" name="action_mod_empl" groups="base.group_system" type="object" class="btn-success"/>
                    <button string="Cloturer" name="action_close_invsession" groups="base.group_system" type="object" class="btn-danger"/>
                    <field name="state" widget="statusbar" readonly="1"/>
                </header>
                <sheet>
                    <group invisible="state != 'Creation'">
                        <group><button string="Suivant" name="action_creation" type="object" class="btn-success"/></group>
                        <group>
                            <field name="magasinPhysique"/>
                            <field name="rack"/>
                            <field name="nbrEmp"/>
                            <field name="magasinSAP"/>
                            <field name="ummondatory" widget="boolean_toggle"/>
                            <field name="dummondatory" widget="boolean_toggle"/>
                            <field name="statusSession" widget="boolean_toggle"/>
                        </group>
                    </group>

                    <group invisible="state != 'Scan'">
                        <group><field name="resume" readonly="1" force_save="1"/></group>
                        <group>
                            <button colspan="3" string="nouvelle emp" name="action_create_empl" type="object" class="btn-warning"/>
                        </group>
                        <field name="recs_scan" nolabel="1" readonly="1" colspan="2">
                        <list create="false" delete="false" edit="false" editable="bottom">
                                <field name="emplacement"/>
                                <field name="su"/>
                                <field name="ok_done"/>
                                <button string="Scanner" name="action_view_form_inv" type="object" alt="Scanner" class="btn btn-small btn-primary"/>
                        </list>
                        </field>
                    </group>

                    <group invisible="state != 'Fermeture'">
                        <group>
                            <h1 style="color: green;" colspan="3">Scan Cloturé</h1>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
</record>

