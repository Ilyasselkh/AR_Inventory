<?xml version="1.0" encoding="utf-8"?>
<odoo>

<record id="AR_Inventory.view_araymond_inventory_form" model="ir.ui.view">
        <field name="name">araymond.inventory.form</field>
        <field name="model">araymond.inventory</field>
        <field name="arch" type="xml">
            <form create="false">
                <header>
                    <button string="Raypro" name="action_raypro" type="object" class="btn-success" />
                    <button string="Reception" name="action_receptionSAP" type="object" class="btn-success" />
                    <button string="Logistique" name="action_logistique" type="object" class="btn-success" />
                    <button string="Manuel" name="action_Manuel" type="object" class="btn-success" />
                    <button string="Cloturer" name="action_close" type="object" class="btn-danger" />
                    <button string="Ecarts SAP vs 1er scan" name="action_show_ecarts_sapvs1scan" groups="base.group_system" type="object" class="btn-danger" />
                    <button string="Ecarts 1er vs 2eme scan" name="action_show_ecarts_1vs2scan" groups="base.group_system" type="object" class="btn-danger" />
                    <button string="Ecarts 2eme vs 3eme scan" name="action_show_ecarts_2vs3scan" groups="base.group_system" type="object" class="btn-danger" />
                    <button string="voir les SU disponibles" name="action_show_su_lxo3" groups="base.group_system" type="object" class="btn-danger" />
                </header>

                <sheet>
                    <group invisible="ok_done == True and is_admin == False">
                        <field name="ok_done" invisible="is_admin == False"/>
                        <field name="is_admin" invisible="1"/>
                        <field name="typedegalia" invisible="1"/>
                        <field name="um2Active" invisible="1"/>
                        <field name="emplacementVidefieldCheck" invisible="1"/>

                        <h1 invisible="um2Active == False" style="color: red;" colspan="3">Un deuxieme scan UM est necessaire</h1>

                        <field name="scanraypro" invisible="typedegalia != 'RayPro'" readonly="emplacementVide == True"/>
                        <field name="scanlog" invisible="typedegalia != 'logistique'" readonly="emplacementVide == True"/>
                        <field name="scanrecp" invisible="typedegalia != 'ReceptionSAP'" readonly="emplacementVide == True"/>
                        <field name="count_box_scanne"/>
                        <field name="emplacementVide" invisible="emplacementVidefieldCheck == False"/>
                        <field name="EmpAnomaly"/>
                        <field name="commentaire"/>
                        <field name="emplacement" readonly="typedegalia not in ('ReceptionSAP', 'Manuel', 'logistique')" force_save="1"/>
                        <field name="rec_scan_id" invisible="1" groups="base.group_system"/>
                        <field name="ref" invisible="typedegalia not in ('logistique', 'Manuel')" readonly="typedegalia not in ('Manuel',)"/>
                        <field name="qty" invisible="typedegalia not in ('logistique', 'Manuel')" readonly="typedegalia not in ('Manuel',)"/>
                        <field name="lot" invisible="typedegalia not in ('logistique', 'Manuel')" readonly="typedegalia not in ('Manuel',)"/>
                        <field name="hu" invisible="typedegalia not in ('logistique',)" readonly="typedegalia not in ('Manuel',)"/>
                        <field name="numEtiquet" invisible="typedegalia not in ('Manuel',)" readonly="typedegalia not in ('Manuel',)"/>
                        <field name="hu" readonly="1" invisible="typedegalia != 'ReceptionSAP'"/>
                        <field name="um" readonly="1" force_save="1" invisible="typedegalia != 'RayPro'"/>
                        <field name="um2" readonly="1" force_save="1" invisible="typedegalia != 'RayPro'"/>
                        <field name="dum" force_save="1" readonly="typedegalia not in ('Manuel',)" invisible="typedegalia != 'Manuel' and not dum"/>
                    </group>
                    <group invisible="emplacementVide == True">
                        <button string="Enregistrer" name="action_manuel_save" type="object" class="btn-warning" invisible="typedegalia not in ('Manuel',)"/>
                    </group>
                    <group>
                        <field name="filtered_su" nolabel="1" colspan="2" readonly="1">
                            <list create="false" edit="false">
                                <field name="ref"/>
                                <field name="qty"/>
                                <field name="of"/>
                                <field name="lot"/>
                                <field name="hu"/>
                                <field name="su"/>
                                <field name="mode"/>
                                <field name="typedegalia"/>
                                <field name="dum"/>
                                <button type="object" icon="fa-times" title="Supprimer" name="unlinkEt"/>
                            </list>
                        </field>
                    </group>
                    <group>
                        <field name="scanNbr" readonly="is_admin == False"/>
                    </group>
                    <field name="rec_scan_id" invisible="is_admin == False"/>
                </sheet>
            </form>
        </field>
</record>

